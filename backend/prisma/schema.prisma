generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Role {
  ADMIN
  ADVISOR
  TECHNICIAN
}

enum JobStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum ServiceType {
  GENERAL
  PAID
  WARRANTY
  COMPLAINT
  BATTERY
  CHARGER
}

enum InspectionCondition {
  OK
  NOT_OK
  DAMAGE
}

enum MediaType {
  IMAGE
  VIDEO
}

enum PartAction {
  NEW
  REPLACE
  REFURBISHED
}

//////////////////////////////////////////////////////
// USERS (AUTH)
//////////////////////////////////////////////////////

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  jobCards JobCard[] @relation("AdvisorJobCards")
}

//////////////////////////////////////////////////////
// CUSTOMERS
//////////////////////////////////////////////////////

model Customer {
  id           Int      @id @default(autoincrement())
  name         String
  mobileNumber String   @unique
  address      String?
  gstNumber    String?
  notes        String?
  createdAt    DateTime @default(now())

  vehicles Vehicle[]
  jobCards JobCard[]
}

//////////////////////////////////////////////////////
// VEHICLES
//////////////////////////////////////////////////////

model Vehicle {
  id                 Int      @id @default(autoincrement())
  customerId         Int
  vinNumber          String   @unique
  model              String
  batchDetails       String?
  batteryNumber      String?
  chargerNumber      String?
  motorNumber        String?
  registrationNumber String?
  warrantyStatus     String?
  createdAt          DateTime @default(now())

  customer Customer  @relation(fields: [customerId], references: [id])
  jobCards JobCard[]
}

//////////////////////////////////////////////////////
// JOB CARDS (CENTRAL ENTITY)
//////////////////////////////////////////////////////

model JobCard {
  id                 Int         @id @default(autoincrement())
  jobCardNumber      String      @unique
  customerId         Int
  vehicleId          Int
  serviceAdvisorId   Int
  serviceInDatetime  DateTime
  serviceType        ServiceType
  status             JobStatus   @default(OPEN)
  odometer           Int?
  batteryVoltage     Float?
  nextServiceDueKm   Int?
  nextServiceDueDate DateTime?
  remarks            String?
  createdAt          DateTime    @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id])
  advisor  User     @relation("AdvisorJobCards", fields: [serviceAdvisorId], references: [id])

  inspections VehicleInspection[]
  complaints  ServiceComplaint[]
  parts       PartsReplacement[]
  media       JobCardMedia[]
}

//////////////////////////////////////////////////////
// VEHICLE INSPECTION
//////////////////////////////////////////////////////

model VehicleInspection {
  id            Int                 @id @default(autoincrement())
  jobCardId     Int
  componentName String
  condition     InspectionCondition

  jobCard JobCard @relation(fields: [jobCardId], references: [id])
}

//////////////////////////////////////////////////////
// SERVICE COMPLAINTS
//////////////////////////////////////////////////////

model ServiceComplaint {
  id        Int         @id @default(autoincrement())
  jobCardId Int
  category  String
  workType  ServiceType

  jobCard JobCard @relation(fields: [jobCardId], references: [id])
}

//////////////////////////////////////////////////////
// PARTS REPLACEMENT
//////////////////////////////////////////////////////

model PartsReplacement {
  id                 Int        @id @default(autoincrement())
  jobCardId          Int
  partName           String
  partNumber         String?
  action             PartAction
  warrantyApplicable Boolean

  jobCard JobCard @relation(fields: [jobCardId], references: [id])
}

//////////////////////////////////////////////////////
// JOB CARD MEDIA (IMAGES / VIDEOS)
//////////////////////////////////////////////////////

model JobCardMedia {
  id         Int       @id @default(autoincrement())
  jobCardId  Int
  mediaType  MediaType
  filePath   String
  uploadedAt DateTime  @default(now())

  jobCard JobCard @relation(fields: [jobCardId], references: [id])
}
